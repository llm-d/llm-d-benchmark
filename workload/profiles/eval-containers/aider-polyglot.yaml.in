# eval-containers / aider-polyglot profile.
#
# The benchmark, agent, task dataset and grader all live in the harness pod
# image (images.benchmark = evals/aider-polyglot--claude-code-standalone); this
# pod selects ONE task by its parallel index and points the eval's in-pod
# gateway at the deployed model. The fields below are informational -- the
# eval-containers entrypoint reads model/endpoint from the environment, not from
# this file (kept for parity with other harness profiles and for the record).
harness: eval-containers
benchmark: aider-polyglot
description: "Exercism polyglot code-editing -- 6 languages, 225 tasks, fully offline, multi-turn."
tasks: 225
internet: false
model: "REPLACE_ENV_LLMDBENCH_DEPLOY_CURRENT_MODEL"
endpoint: "REPLACE_ENV_LLMDBENCH_HARNESS_STACK_ENDPOINT_URL"
