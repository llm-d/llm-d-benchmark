{% if fma is defined and fma.enabled | default(false) %}

{# ============================================================================
   fma-deployment.yaml.j2

   Fast Model Actuation Deployment.
   ============================================================================ #}

apiVersion: fma.llm-d.ai/v1alpha1
kind: InferenceServerConfig
metadata:
  name: fma-{{ model_id_label }}
  labels:
    app: fma-{{ model_id_label }}
{% if fma.labels is defined %}
{% for key, value in fma.labels.items() %}
    {{ key }}: "{{ value }}"
{% endfor %}
{% endif %}
  namespace: {{ namespace.name }}
spec:
  launcherConfigName: fma-{{ model_id_label }}
  modelServerConfig:
    # IMPORTANT: labels here are stamped on the launcher pod at BIND time
    # (when the dual-pods controller pairs a requester to a launcher), not
    # at launcher creation time. Putting EPP/InferencePool routing labels
    # here -- rather than on `LauncherConfig.spec.podTemplate.metadata.labels`
    # -- means idle/unbound launchers don't appear in the InferencePool
    # selector and don't receive traffic before vLLM is actually serving.
    # See PR llm-d-incubation/llm-d-fast-model-actuation#552 README.
    labels:
      component: inference
      # EPP InferencePool selector keys (see 12_router-values.yaml.j2:217-218):
      llm-d.ai/inferenceServing: "{{ labels.inferenceServing | default('true') }}"
      llm-d.ai/model: "{{ model_id_label }}"
{% if wva is defined and wva.enabled | default(false) %}
      # WVA PR #1145: variant label must equal the VariantAutoscaling
      # resource name literally; the ServiceMonitor relabel rule lifts
      # this onto scraped vLLM metrics as `llm_d_ai_variant`.
      llm-d.ai/variant: "{{ model_id_label }}-fma"
{% endif %}
    env_vars:
      HF_HOME: "{{ fma.modelMountPath }}"
      VLLM_LOGGING_LEVEL: DEBUG
      VLLM_SERVER_DEV_MODE: "1"
      VLLM_USE_V1: "1"
    options: "--model {{ model.name }} --enable-sleep-mode --no-enable-prefix-caching --load-format auto --gpu-memory-utilization 0.95 --tensor-parallel-size 1"
    port: 8000
---
apiVersion: fma.llm-d.ai/v1alpha1
kind: LauncherConfig
metadata:
  name: fma-{{ model_id_label }}
  labels:
    app: fma-{{ model_id_label }}
{% if fma.labels is defined %}
{% for key, value in fma.labels.items() %}
    {{ key }}: "{{ value }}"
{% endfor %}
{% endif %}
  namespace: {{ namespace.name }}
spec:
  maxInstances: {{ fma.launcher.maxInstances }}
  podTemplate:
    metadata:
{% if fma.launcher.podTemplate.metadata.labels is defined %}
      # Routing/variant labels intentionally NOT here -- they belong on the
      # InferenceServerConfig.spec.modelServerConfig.labels block above so
      # the dual-pods controller stamps them on the launcher pod at BIND
      # time (only when a requester is actively using it). See PR llm-d-
      # incubation/llm-d-fast-model-actuation#552 README.
      labels:
{% for key, value in fma.launcher.podTemplate.metadata.labels.items() %}
        {{ key }}: "{{ value }}"
{% endfor %}
{% endif %}
{% if fma.launcher.podTemplate.metadata.annotations is defined %}
      annotations:
{% for key, value in fma.launcher.podTemplate.metadata.annotations.items() %}
        {{ key }}: "{{ value }}"
{% endfor %}
{% endif %}
    spec:
{% if fma.launcher.runtimeClassName is defined and fma.launcher.runtimeClassName %}
      runtimeClassName: {{ fma.launcher.runtimeClassName }}
{% endif %}
      containers:
        - name: inference-server
          image: {{ fma.launcher.image.repository }}:{{ fma.launcher.image.tag }}
          imagePullPolicy: {{ fma.launcher.image.pullPolicy }}
          # No named port for vllm-metrics: 18_podmonitor.yaml.j2 forces the
          # scrape address to <pod-ip>:8000 via a relabel rule (matches the
          # pattern used by PR llm-d-incubation/llm-d-fast-model-actuation#552).
          # That sidesteps the named-port question entirely.
          command:
            - /bin/bash
            - "-c"
          args:
            - |
{% if fma.launcher.customPreprocessCommands is defined %}
{% for command in fma.launcher.customPreprocessCommands %}
              {{ command }}
{% endfor %}
{% endif %}
              exec python3 /app/launcher.py \
              --host 0.0.0.0 \
              --log-level info \
              --port={{ fma.launcherConfigurator.port }}
          env:
          - name: HOME
            value: "{{ fma.modelMountPath }}"
          - name: VLLM_CACHE_ROOT
            value: "{{ fma.modelMountPath }}/vllm"
          - name: FLASHINFER_WORKSPACE_DIR
            value: "{{ fma.modelMountPath }}/flashinfer"
          - name: TRITON_CACHE_DIR
            value: "{{ fma.modelMountPath }}/triton"
          - name: XDG_CACHE_HOME
            value: "{{ fma.modelMountPath }}"
          - name: XDG_CONFIG_HOME
            value: "{{ fma.modelMountPath }}/config"
          - name: HF_HOME
            value: "{{ fma.modelMountPath }}"
{% if huggingface.enabled and huggingface.secretName is defined and huggingface.secretName %}
          - name: HF_TOKEN
            valueFrom:
              secretKeyRef:
                name: {{ huggingface.secretName }}
                key:  {{ huggingface.tokenKey }}
{% endif %}
          resources:
            limits:
              nvidia.com/gpu: "1"
            requests:
              nvidia.com/gpu: "1"
          volumeMounts:
{% if fma.mountModelVolume %}
          - name: model-cache
            mountPath: {{ fma.modelMountPath }}
            readOnly: False
{% endif %}
      volumes:
{% if fma.mountModelVolume %}
      - name: model-cache
        persistentVolumeClaim:
          claimName: {{ fma.modelPvcName }}
{% endif %}
---
apiVersion: fma.llm-d.ai/v1alpha1
kind: LauncherPopulationPolicy
metadata:
  name: fma-{{ model_id_label }}
  labels:
    app: fma-{{ model_id_label }}
{% if fma.labels is defined %}
{% for key, value in fma.labels.items() %}
    {{ key }}: "{{ value }}"
{% endfor %}
{% endif %}
  namespace: {{ namespace.name }}
spec:
  enhancedNodeSelector:
    labelSelector:
      matchLabels:
        nvidia.com/gpu.present: "true"
  countForLauncher:
    - launcherConfigName: fma-{{ model_id_label }}
      launcherCount: 1
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: fma-requester-{{ model_id_label }}
  labels:
    app: fma-requester-{{ model_id_label }}
{% if fma.labels is defined %}
{% for key, value in fma.labels.items() %}
    {{ key }}: "{{ value }}"
{% endfor %}
{% endif %}
  namespace: {{ namespace.name }}
spec:
  replicas: 0
  selector:
    matchLabels:
      app: dp-app
      llm-d.ai/inference-serving: "true"
      llm-d.ai/model: {{ model_id_label }}
      llm-d.ai/role: requester
  template:
    metadata:
      labels:
        app: dp-app
        llm-d.ai/inference-serving: "true"
        llm-d.ai/model: {{ model_id_label }}
        llm-d.ai/role: requester
      annotations:
        dual-pods.llm-d.ai/admin-port: "8081"
        dual-pods.llm-d.ai/inference-server-config: fma-{{ model_id_label }}
    spec:
      containers:
        - name: inference-server
          image: {{ fma.requester.image.repository }}:{{ fma.requester.image.tag }}
          imagePullPolicy: {{ fma.requester.image.pullPolicy }}
          command:
          - /app/requester
          ports:
          - name: probes
            containerPort: {{ fma.requester.probePort }}
          - name: spi
            containerPort: {{ fma.requester.spiPort }}
          readinessProbe:
            httpGet:
              path: /ready
              port: 8080
            initialDelaySeconds: 2
            periodSeconds: 5
          resources:
            limits:
              nvidia.com/gpu: {{ fma.requester.limitsGPU }}
              cpu: {{ fma.requester.limitsCPU }}
              memory: {{ fma.requester.limitsMemory }}

{% endif %}
