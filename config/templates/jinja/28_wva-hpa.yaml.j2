{# ============================================================================
   28_wva-hpa.yaml.j2

   Per-stack HorizontalPodAutoscaler. WVA's annotation-based discovery path:
   the controller reconciles every HPA carrying `llm-d.ai/managed: "true"`,
   computes the desired replica count for the variant, and emits the
   `wva_desired_replicas{variant_name=<hpa name>, exported_namespace=<ns>}`
   external metric this HPA reads back via prometheus-adapter.

   WVA discovers everything via the three opt-in annotations
   (managed, model-id, variant-cost).

   Only rendered when wva.enabled is true.
   ============================================================================ #}
{% if wva is defined and wva.enabled | default(false) %}
{% if fma is defined and fma.enabled | default(false) %}
{% set scale_kind = 'Deployment' %}
{% set scale_name = 'fma-requester-' ~ model_id_label %}
{% set variant_suffix = 'fma' %}
{% else %}
{% set scale_kind = 'Deployment' %}
{% set scale_name = model_id_label ~ '-decode' %}
{% set variant_suffix = 'decode' %}
{% endif %}
{% set hpa_name = model_id_label ~ '-' ~ variant_suffix %}
apiVersion: autoscaling/v2
kind: HorizontalPodAutoscaler
metadata:
  name: {{ hpa_name }}
  namespace: {{ wva.namespace | default(namespace.name, true) }}
  annotations:
    llm-d.ai/managed: "true"
    llm-d.ai/model-id: "{{ model.name }}"
    llm-d.ai/variant-cost: "{{ wva.variantAutoscaling.variantCost | default('10.0') }}"
spec:
  scaleTargetRef:
    apiVersion: apps/v1
    kind: {{ scale_kind }}
    name: {{ scale_name }}
  minReplicas: {{ wva.hpa.minReplicas | default(1) }}
  maxReplicas: {{ wva.hpa.maxReplicas | default(16) }}
  metrics:
    - type: External
      external:
        metric:
          name: wva_desired_replicas
          selector:
            matchLabels:
              variant_name: {{ hpa_name }}
              exported_namespace: {{ wva.namespace | default(namespace.name, true) }}
        target:
          type: AverageValue
          averageValue: "{{ wva.hpa.targetAvgValue | default(1) }}"
{% if wva.hpa.behavior is defined %}
  behavior:
{{ wva.hpa.behavior | toyaml | indent(4, first=True) }}
{% endif %}
{% endif %}
