{# ============================================================================
   18_podmonitor.yaml.j2

   PodMonitor for Prometheus to scrape vLLM model serving pods deployed via
   modelservice (decode/prefill) or FMA (launcher pods). Only rendered when
   monitoring.podmonitor.enabled is true. Matches bash step 09
   generate_podmonitor_yaml().
   ============================================================================ #}
{% if monitoring is defined and monitoring.podmonitor is defined and monitoring.podmonitor.enabled | default(false) %}
{% set _fma_enabled = (fma is defined and fma.enabled | default(false)) %}
{% set _wva_enabled = (wva is defined and wva.enabled | default(false)) %}
apiVersion: monitoring.coreos.com/v1
kind: PodMonitor
metadata:
  name: vllm-{{ model_id_label }}
  namespace: {{ namespace.name }}
  labels:
{% if _wva_enabled %}
    release: llmd
{% endif %}
{% if annotations is defined and annotations.common is defined and annotations.common %}
{% for key, value in annotations.common.items() %}
    {{ key }}: "{{ value }}"
{% endfor %}
{% endif %}
spec:
  selector:
    matchLabels:
{% if _wva_enabled %}
      # WVA paths (FMA-launcher AND modelservice-decode) both stamp
      # `llm-d.ai/guide` on serving pods (FMA via 24_fma-deployment.yaml.j2's
      # ISC labels stamped at bind time; modelservice via 13_ms-values.yaml.j2).
      # Selecting on `guide` keeps the PodMonitor identical for both paths
      # — same as Braulio's working FMA+WVA setup in PR #552/#579.
      llm-d.ai/guide: "{{ wva.wellLitPath | default('optimized-baseline') }}"
{% else %}
      llm-d.ai/inferenceServing: "{{ labels.inferenceServing }}"
      llm-d.ai/model: {{ model_id_label }}
{% endif %}
  podMetricsEndpoints:
{% if _fma_enabled %}
  - interval: {{ monitoring.scrapeInterval | default('30s') }}
    path: {{ monitoring.metricsPath | default('/metrics') }}
    relabelings:
      - sourceLabels: [__meta_kubernetes_pod_container_name]
        action: keep
        regex: inference-server
      # Force scrape target to <pod-ip>:8000 -- vLLM's port inside the launcher
      # (matches InferenceServerConfig.spec.modelServerConfig.port).
      - sourceLabels: [__meta_kubernetes_pod_ip]
        action: replace
        regex: (.+)
        replacement: $1:8000
        targetLabel: __address__
{% if _wva_enabled %}
      - sourceLabels: [__meta_kubernetes_pod_label_llm_d_ai_variant]
        action: replace
        targetLabel: llm_d_ai_variant
{% endif %}
{% else %}
  - port: {{ monitoring.podmonitor.portName | default('metrics') }}
    path: {{ monitoring.metricsPath | default('/metrics') }}
    interval: {{ monitoring.scrapeInterval | default('30s') }}
{% if _wva_enabled %}
    relabelings:
      - sourceLabels: [__meta_kubernetes_pod_label_llm_d_ai_variant]
        action: replace
        targetLabel: llm_d_ai_variant
{% endif %}
{% endif %}
{% endif %}
