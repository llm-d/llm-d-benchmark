# OpenShift Container Platform CI/CD Specification - FMA + WVA
# CICD variant of guides/workload-autoscaling, exercising the FMA+WVA path
# under inference-perf load.
# See scenarios/cicd/ocp-fma-wva.yaml for details.

# [REQUIRED]
{% set base_dir = base_dir | default('../') -%}
base_dir: {{ base_dir }}

# [REQUIRED]
values_file:
  path: {{ base_dir }}/config/templates/values/defaults.yaml

# [REQUIRED]
template_dir:
  path: {{ base_dir }}/config/templates/jinja

# [OPTIONAL]
scenario_file:
  path: {{ base_dir }}/config/scenarios/cicd/ocp-fma-wva.yaml
