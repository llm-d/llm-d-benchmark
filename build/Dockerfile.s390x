ARG BASE_UBI_IMAGE_TAG=9.6
FROM registry.access.redhat.com/ubi9/ubi-minimal:${BASE_UBI_IMAGE_TAG}

USER root

WORKDIR /workspace

# =========================================================
# SYSTEM PACKAGES
# =========================================================
RUN microdnf clean all && microdnf makecache && \
    microdnf install -y \
    git jq rsync wget tar \
    which findutils \
    bc procps-ng coreutils \
    gcc gcc-c++ gcc-gfortran make cmake ninja-build \
    autoconf automake libtool pkg-config \
    openssl-devel libffi-devel zlib-devel \
    bzip2-devel xz-devel lz4-devel snappy-devel libzstd-devel \
    freetype-devel boost-devel \
    openblas openblas-devel \
    libjpeg-turbo-devel libtiff-devel libpng-devel libwebp-devel \
    libxml2 libxml2-devel libxslt libxslt-devel \
    ca-certificates iproute infiniband-diags \
    perl-core dnf-plugins-core \
    libsndfile \
    && microdnf clean all

# =========================================================
# INSTALL PYTHON 3.12
# =========================================================
RUN microdnf install -y \
    python3.12 \
    python3.12-pip \
    python3.12-devel && \
    microdnf clean all
=============================

# PYTHON
# =========================================================
RUN ln -sf /usr/bin/python3.12 /usr/bin/python && \
    ln -sf /usr/bin/python3.12 /usr/bin/python3

RUN python -m ensurepip || true
RUN python -m pip install --upgrade pip setuptools wheel cython build
# =========================================================
# RUST
# =========================================================
RUN curl https://sh.rustup.rs -sSf | sh -s -- -y

ENV PATH="/root/.cargo/bin:${PATH}"

RUN rustc --version

# =========================================================
# YQ
# =========================================================
RUN ARCH=$(uname -m) && \
    wget -q \
    https://github.com/mikefarah/yq/releases/latest/download/yq_linux_${ARCH} \
    -O /usr/local/bin/yq && \
    chmod +x /usr/local/bin/yq

# =========================================================
# OPENSHIFT OC
# =========================================================
RUN ARCH=$(uname -m) && \
    curl -LO \
    https://mirror.openshift.com/pub/openshift-v4/clients/ocp/latest-4.20/openshift-client-linux-${ARCH}-rhel9.tar.gz && \
    tar -xzf openshift-client-linux-${ARCH}-rhel9.tar.gz -C /usr/local/bin oc && \
    chmod +x /usr/local/bin/oc && \
    rm -f *.tar.gz

# =========================================================
# KUBECTL
# =========================================================
ARG KUBE_VERSION=v1.20.0

RUN ARCH=$(uname -m) && \
    curl -LO https://dl.k8s.io/${KUBE_VERSION}/bin/linux/${ARCH}/kubectl && \
    chmod +x kubectl && \
    mv kubectl /usr/local/bin/

# =========================================================
# APACHE ARROW
# =========================================================
WORKDIR /tmp

ENV ARROW_HOME=/usr/local
ENV CMAKE_PREFIX_PATH=/usr/local
ENV LD_LIBRARY_PATH=/usr/local/lib:/usr/local/lib64

RUN git clone https://github.com/apache/arrow.git && \
    cd arrow/cpp && \
    mkdir release && \
    cd release && \
    cmake \
      -DCMAKE_BUILD_TYPE=Release \
      -DCMAKE_INSTALL_PREFIX=/usr/local \
      -DARROW_PYTHON=ON \
      -DARROW_PARQUET=OFF \
      -DARROW_DATASET=ON \
      -DARROW_WITH_SNAPPY=ON \
      -DARROW_WITH_ZSTD=ON \
      -DARROW_WITH_LZ4=ON \
      -DARROW_DEPENDENCY_SOURCE=BUNDLED \
      .. && \
    make -j$(nproc) && \
    make install && \
    echo "/usr/local/lib" > /etc/ld.so.conf.d/arrow.conf && \
    echo "/usr/local/lib64" >> /etc/ld.so.conf.d/arrow.conf && \
    ldconfig

# =========================================================
# PYARROW
# =========================================================
RUN pip install build

RUN cd /tmp/arrow/python && \
    export PYARROW_BUNDLE_ARROW_CPP=1 && \
    export PYARROW_WITH_DATASET=1 && \
    export ARROW_HOME=/usr/local && \
    export PARQUET_HOME=/usr/local && \
    python -m build --wheel

RUN pip install /tmp/arrow/python/dist/*.whl

# =========================================================
# VERIFY PYARROW
# =========================================================
RUN find /usr/local -name "libarrow_dataset*" && \
    python -c "import pyarrow; print(pyarrow.__version__)" && \
    python -c "import pyarrow.dataset as ds; print('dataset OK')"

# =========================================================
# INFERENCE PERF
# =========================================================
WORKDIR /tmp

RUN git clone https://github.com/kubernetes-sigs/inference-perf.git

RUN cd inference-perf && \
    git checkout v0.4.0 && \
    pip install .

# =========================================================
# GUIDELLM
# =========================================================
RUN pip install --no-cache-dir guidellm

RUN which guidellm

# =========================================================
# WORKSPACE
# =========================================================
WORKDIR /workspace

COPY . /workspace

# =========================================================
# REQUIREMENTS
# =========================================================
RUN if [ -f build/requirements-analysis.txt ]; then \
      pip install --no-cache-dir -r build/requirements-analysis.txt; \
    fi

# =========================================================
# HARNESS SCRIPTS
# =========================================================
RUN cp -r /workspace/workload/harnesses/* /usr/local/bin/ || true

RUN chmod +x /usr/local/bin/*.sh || true

RUN ls -lrt /usr/local/bin/guidellm* || true

# =========================================================
# FINAL VERIFY
# =========================================================
RUN python -c "import pyarrow.dataset as ds; print('runtime dataset OK')" && \
    guidellm --help >/dev/null



# =========================================================
# COPY ENTRYPOINT SCRIPT
# =========================================================
COPY build/llm-d-benchmark.sh /usr/local/bin/llm-d-benchmark.sh
RUN chmod +x /usr/local/bin/llm-d-benchmark.sh


# =========================================================
# ENTRYPOINT
# =========================================================
ENTRYPOINT ["/usr/local/bin/llm-d-benchmark.sh"]

